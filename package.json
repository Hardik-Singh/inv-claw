{
  "name": "inv-claw",
  "version": "0.1.0",
  "description": "Measure everything your OpenClaw does — every change, every command, full results",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && cp -r dashboard dist/dashboard",
    "dev": "tsc --watch",
    "server": "node dist/server.js"
  },
  "openclaw": {
    "extensions": ["dist/index.js"]
  },
  "keywords": ["openclaw", "plugin", "audit", "logging", "invariance", "inv-claw"],
  "author": "Hardik Singh",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "typescript": "^5.3.0"
  }
}
