{
  "name": "invariance-audit",
  "version": "0.1.0",
  "description": "Passive audit logging plugin for OpenClaw agents — local SQLite + dashboard",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dashboard": "python3 server.py"
  },
  "openclaw": {
    "type": "plugin",
    "hooks": ["command:new"]
  },
  "keywords": ["openclaw", "plugin", "audit", "logging", "invariance"],
  "author": "Hardik Singh",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0"
  }
}
